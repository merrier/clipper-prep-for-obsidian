{
  "name": "obsidian-clipper-extended",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A Chromium MV3 extension scaffold for extending Obsidian web clipping workflows.",
  "scripts": {
    "dev": "wxt -b chrome",
    "build": "wxt build -b chrome",
    "zip": "wxt zip -b chrome",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@wxt-dev/module-react": "^1.2.2",
    "eslint": "^9.27.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.4",
    "wxt": "^0.20.26"
  },
  "overrides": {
    "publish-browser-extension": "3.0.2"
  },
  "engines": {
    "node": ">=20"
  }
}
